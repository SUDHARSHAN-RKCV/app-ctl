# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:passq123@localhost:5432/postgres

# ─── Health Monitor ─────────────────────────────────────────────────────────
CHECK_INTERVAL_SECONDS=30      # how often to poll all apps
DOWN_ALERT_MINUTES=5           # alert threshold in minutes

# ─── Email Alerts (Gmail example) ───────────────────────────────────────────
# Use an App Password, not your real password.
# Gmail: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-char-app-password
ALERT_FROM=AppCTL Monitor <you@gmail.com>
ALERT_TO=you@gmail.com,oncall@yourcompany.com
